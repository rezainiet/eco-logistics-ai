{
  "name": "ecommerce-logistics",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm --workspace @ecom/branding run build --if-present",
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspaces run build --if-present",
    "typecheck": "npm --workspaces run typecheck --if-present",
    "lint": "npm --workspaces run lint --if-present",
    "test:e2e": "npm --workspace @ecom/web run test:e2e",
    "test:e2e:install": "npm --workspace @ecom/web run test:e2e:install"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
