# --- Backend (apps/api) ---
API_PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/ecommerce
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me-with-a-long-random-string
# Required in production. Used for /admin/* ops endpoints (X-Admin-Secret header).
ADMIN_SECRET=replace-me-with-a-long-random-string-min-24-chars
# Trial length for new merchants (days).
TRIAL_DAYS=14
# Required in production. AES-256-GCM key for courier credential encryption.
# Generate with: openssl rand -base64 32
COURIER_ENC_KEY=
CORS_ORIGIN=http://localhost:3000

# --- Twilio (optional in dev) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=

# --- Courier defaults ---
# Per-merchant baseUrl (Merchant.couriers[].baseUrl) overrides these.
# Pathao sandbox: https://courier-api-sandbox.pathao.com
PATHAO_BASE_URL=https://api-hermes.pathao.com
STEADFAST_BASE_URL=https://portal.packzy.com
REDX_BASE_URL=https://openapi.redx.com.bd
# Set to "1" to use in-memory mock responses for all courier adapters — ideal
# when live sandbox credentials aren't available. Auto-on under NODE_ENV=test.
COURIER_MOCK=0
# Tracking sync cadence. 0 disables the repeatable job.
TRACKING_SYNC_INTERVAL_MIN=10
TRACKING_SYNC_BATCH=100

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
