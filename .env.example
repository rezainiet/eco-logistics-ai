# --- Backend (apps/api) ---
API_PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/ecommerce
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me-with-a-long-random-string
# Required in production. Used for /admin/* ops endpoints (X-Admin-Secret header).
ADMIN_SECRET=replace-me-with-a-long-random-string-min-24-chars
# Trial length for new merchants (days).
TRIAL_DAYS=14
# REQUIRED in EVERY environment (dev/test/staging/prod). AES-256-GCM key for courier credential encryption.
# Generate with: openssl rand -base64 32
COURIER_ENC_KEY=
CORS_ORIGIN=http://localhost:3001

# --- Twilio (optional in dev) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=

# --- Shopify Partner app (ONE-TIME platform setup, not per-merchant) ---
# This is the standard Shopify OAuth pattern — you (the platform) register
# ONE Partner app, set its credentials here once, and from that point on
# every merchant can connect with pure one-click OAuth: they type their
# shop domain, log into THEIR Shopify, click Approve, and we get a
# merchant-specific access token. Merchants never see or paste API keys.
#
# Without these, the per-store custom-app fallback (Advanced panel) is
# the only path. That fallback is for the rare power-user merchant who
# wants their own custom-scoped app — not the default flow.
#
# How to obtain (10 minutes, free):
#   1. Sign up at https://partners.shopify.com
#   2. Apps -> Create app -> "Public app" -> name it after your platform
#   3. App URL:           http://localhost:3001/dashboard/integrations
#      (production: https://your-domain.com/dashboard/integrations)
#   4. Allowed redirect URL — add BOTH for dev + prod, comma-separated:
#        http://localhost:4000/api/integrations/oauth/shopify/callback
#        https://api.your-domain.com/api/integrations/oauth/shopify/callback
#   5. Copy the Client ID     -> SHOPIFY_APP_API_KEY
#   6. Copy the Client secret -> SHOPIFY_APP_API_SECRET
#   7. Set PUBLIC_API_URL below to match the API origin Shopify will hit
#      (default localhost:4000 is fine for dev)
#   8. Restart `apps/api`. Reload /dashboard/integrations — the green
#      "One-click connect" pill is now truthful for every merchant.
SHOPIFY_APP_API_KEY=
SHOPIFY_APP_API_SECRET=
# Public origin of apps/api as Shopify (and merchants' browsers) will
# reach it. Used to build the OAuth redirect URI AND the GDPR webhook
# URLs. Must match the Allowed-redirect-URL you registered with
# Shopify.
PUBLIC_API_URL=http://localhost:4000
# Public origin of apps/web as merchants' browsers will reach it.
# Used by the OAuth callback to build the post-install redirect back
# to /dashboard/integrations. Must match the App URL you registered
# with Shopify.
PUBLIC_WEB_URL=http://localhost:3001

# === Going to PRODUCTION (Public Distribution / Unlisted) ===
# When you flip the Partner-app from Custom Distribution to Public
# Distribution (Unlisted), the Partner Dashboard form requires URLs
# that match what's set here. Mismatch = silent install failures or
# review rejection. Use this checklist:
#
#   Partner Dashboard field          Must equal in env / config
#   ───────────────────────────────  ──────────────────────────────────────
#   App URL                          PUBLIC_WEB_URL + /dashboard/integrations
#   Allowed redirection URL(s)       PUBLIC_API_URL + /api/integrations/oauth/shopify/callback
#   Privacy policy URL               PUBLIC_WEB_URL + /legal/privacy
#   Terms of service URL             PUBLIC_WEB_URL + /legal/terms
#   GDPR — Customer data request     PUBLIC_API_URL + /api/webhooks/shopify/gdpr/customers/data_request
#   GDPR — Customer redact           PUBLIC_API_URL + /api/webhooks/shopify/gdpr/customers/redact
#   GDPR — Shop redact               PUBLIC_API_URL + /api/webhooks/shopify/gdpr/shop/redact
#
# Production env should set:
#   PUBLIC_API_URL=https://api.your-domain.com
#   PUBLIC_WEB_URL=https://app.your-domain.com
#
# Also mirror PUBLIC_API_URL into the web env (NEXT_PUBLIC_API_URL
# below) and re-run the deploy. The web client uses NEXT_PUBLIC_API_URL
# to build tRPC requests; the API uses PUBLIC_API_URL for its
# self-referential redirect URIs.
#
# After flipping the env vars + redeploying, also re-register the
# Shopify webhooks for any existing connected merchants — the
# callback_url stored on Shopify's side will still point at the old
# host until you reconnect or run the retryShopifyWebhooks tRPC
# mutation. The simplest path is to roll out new redirect URL,
# regress-test ONE merchant via reconnect, then bulk-retry the rest.

# --- Courier defaults ---
# Per-merchant baseUrl (Merchant.couriers[].baseUrl) overrides these.
# Pathao sandbox: https://courier-api-sandbox.pathao.com
PATHAO_BASE_URL=https://api-hermes.pathao.com
STEADFAST_BASE_URL=https://portal.packzy.com
REDX_BASE_URL=https://openapi.redx.com.bd
# Set to "1" to use in-memory mock responses for all courier adapters — ideal
# when live sandbox credentials aren't available. Auto-on under NODE_ENV=test.
COURIER_MOCK=0
# Tracking sync cadence. 0 disables the repeatable job.
TRACKING_SYNC_INTERVAL_MIN=10
TRACKING_SYNC_BATCH=100


# --- SMS (Bangladesh — SSL Wireless) ---
# Get keys from https://smsplus.sslwireless.com/. SSL_WIRELESS_SID is the
# alpha sender (e.g. 'YOURBRAND', 11 chars max) registered with BTRC.
# Leave the three keys empty in dev — sms module logs to stdout instead.
SSL_WIRELESS_API_KEY=
SSL_WIRELESS_USER=
SSL_WIRELESS_SID=
SSL_WIRELESS_DEFAULT_SENDER=
SSL_WIRELESS_BASE_URL=https://smsplus.sslwireless.com

# --- Bangladesh manual payments (bKash / Nagad / bank) ---
# Shown to merchants on /dashboard/billing. Leave blank to hide that option.
PAY_BKASH_NUMBER=
PAY_BKASH_TYPE=Send Money
PAY_NAGAD_NUMBER=
PAY_NAGAD_TYPE=Send Money
PAY_BANK_INFO=
# Daily submission cap per merchant (defends against spam).
PAY_MANUAL_DAILY_CAP=3

# --- Cross-merchant fraud network ---
# 1 = on (default), 0 = off (emergency disable)
FRAUD_NETWORK_ENABLED=1
# Days after which a signal stops contributing to the bonus.
FRAUD_NETWORK_DECAY_DAYS=180
# Total signals below which bonuses are halved (early-rollout safety).
FRAUD_NETWORK_WARMING_FLOOR=50

# Shared secret for SMS inbound + DLR webhook HMAC verification.
# Set this to the secret value you configure in your SMS gateway.
# Required in production. Dev/staging may leave it blank with a warning.
SMS_WEBHOOK_SHARED_SECRET=
# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=replace-me-with-a-long-random-string

# --- Merchant support (frontend, optional) ---
# WhatsApp number including country code, e.g. 8801712345678. If both
# WHATSAPP and URL are set, the WhatsApp link wins.
NEXT_PUBLIC_SUPPORT_WHATSAPP=
# Fallback URL — your help-desk, Intercom, mailto:, etc.
NEXT_PUBLIC_SUPPORT_URL=
