# Web runs on port 3001 (port 3000 is intentionally left free for whatever
# other project the dev has running locally). NEXTAUTH_URL MUST match the web
# port — if it disagrees, signOut() and post-login redirects send the user to
# the wrong origin and they end up on a stranger's app.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
