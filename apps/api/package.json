{
  "name": "@ecom/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "seed:wipe": "tsx src/scripts/seed.ts --wipe",
    "db:sync-indexes": "tsx src/scripts/syncIndexes.ts",
    "stripe:seed": "tsx src/scripts/seedStripe.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ecom/db": "*",
    "@ecom/types": "*",
    "@trpc/server": "^10.45.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.75.2",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.3.5",
    "mongoose": "^8.5.1",
    "rate-limit-redis": "^4.3.1",
    "twilio": "^5.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.11",
    "mongodb-memory-server": "^10.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
