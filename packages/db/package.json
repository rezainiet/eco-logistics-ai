{
  "name": "@ecom/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit false --outDir dist --rootDir src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mongoose": "^8.5.1"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
