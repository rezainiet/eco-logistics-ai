{
  "name": "@ecom/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json",
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
